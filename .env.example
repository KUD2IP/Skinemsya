# Copy to .env in the repository root and fill in values for local development.
# Do not commit .env to version control.
#
# Spring Boot loads this file via spring.config.import (see application.yml).

SPRING_PROFILES_ACTIVE=dev

DB_URL=jdbc:postgresql://localhost:5432/skinemsya
DB_USER=skinemsya
DB_PASSWORD=skinemsya
SERVER_PORT=8080

# Required from Phase 2 (Auth & Users)
JWT_SECRET=dev-secret-min-32-characters-long
TELEGRAM_BOT_TOKEN=

# Bot username without @ (optional: resolved automatically via getMe if omitted)
TELEGRAM_BOT_USERNAME=

# Mini App URL for private chats (web_app button)
TELEGRAM_MINI_APP_URL=http://localhost:5173

# Optional: short name from BotFather /newapp (https://t.me/bot/shortname)
TELEGRAM_WEB_APP_SHORT_NAME=

# Long polling for bot updates (default true; set false if using webhook only)
TELEGRAM_BOT_POLLING_ENABLED=true

# Optional: protect POST /api/v1/integrations/telegram/webhook (setWebhook secret_token)
TELEGRAM_WEBHOOK_SECRET=

# Comma-separated origins for Mini App frontend (add your hosting URL if not localhost)
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,https://web.telegram.org

# Optional
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_TIMEOUT=30s
FILE_STORAGE_PATH=./storage
