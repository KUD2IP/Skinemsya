# Шаблон для production. Скопируй в локальный файл, заполни секреты,
# затем добавь содержимое в GitHub → Settings → Environments → production:
#   PRODUCTION_ENV (multiline secret)
# APP_VERSION и GHCR_OWNER дописываются автоматически в CI при деплое.
# GHCR_OWNER — владелец пакета GitHub (user или org), lowercase.

GHCR_OWNER=your-github-owner

APP_DOMAIN=skinemsya-vse.ru
ACME_EMAIL=you@example.com

POSTGRES_DB=skinemsya
POSTGRES_USER=skinemsya
POSTGRES_PASSWORD=change-me-long-random

JWT_SECRET=change-me-min-32-characters-random-string
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_MINI_APP_URL=https://skinemsya-vse.ru
TELEGRAM_WEB_APP_SHORT_NAME=skinemsya
TELEGRAM_BOT_POLLING_ENABLED=true
TELEGRAM_WEBHOOK_SECRET=

S3_REGION=us-east-1
S3_BUCKET=skinemsya-files
S3_ACCESS_KEY=skinemsya
S3_SECRET_KEY=change-me-long-random

ML_SERVICE_URL=
