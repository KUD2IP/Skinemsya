# Шаблон для staging. Скопируй в локальный файл, заполни секреты,
# затем загрузи содержимое в GitFlic как ОДНУ переменную STAGING_ENV_FILE (тип «Файл»).
# APP_VERSION дописывается автоматически в CI при деплое.

APP_DOMAIN=skinemsya-vse.ru
ACME_EMAIL=you@example.com

POSTGRES_DB=skinemsya
POSTGRES_USER=skinemsya
POSTGRES_PASSWORD=change-me-long-random

JWT_SECRET=change-me-min-32-characters-random-string
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_MINI_APP_URL=https://skinemsya-vse.ru
TELEGRAM_WEB_APP_SHORT_NAME=
TELEGRAM_BOT_POLLING_ENABLED=true
TELEGRAM_WEBHOOK_SECRET=

S3_REGION=us-east-1
S3_BUCKET=skinemsya-files
S3_ACCESS_KEY=skinemsya
S3_SECRET_KEY=change-me-long-random

ML_SERVICE_URL=
