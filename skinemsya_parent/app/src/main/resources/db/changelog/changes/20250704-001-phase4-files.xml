<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20250704-001-files" author="skinemsya">
        <createTable tableName="files">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="owner_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_files_owner"
                             references="users(id)"/>
            </column>
            <column name="original_name" type="VARCHAR(255)"/>
            <column name="mime_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="size_bytes" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="storage_path" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
